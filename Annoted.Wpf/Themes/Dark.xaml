<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Core palette -->
    <Color x:Key="BackgroundColor">#FF1E1E1E</Color>
    <Color x:Key="SurfaceColor">#FF252526</Color>
    <Color x:Key="SidebarColor">#FF252526</Color>
    <Color x:Key="EditorBackColor">#FF1E1E1E</Color>
    <Color x:Key="ForeColor">#FFD4D4D4</Color>
    <Color x:Key="MutedForeColor">#FF888888</Color>
    <Color x:Key="AccentColor">#FF007ACC</Color>
    <Color x:Key="AccentHoverColor">#FF1177BB</Color>
    <Color x:Key="BorderColor">#FF3E3E42</Color>
    <Color x:Key="TabActiveColor">#FF1E1E1E</Color>
    <Color x:Key="TabInactiveColor">#FF2D2D30</Color>
    <Color x:Key="ButtonHoverColor">#FF3E3E42</Color>
    <Color x:Key="ButtonPressedColor">#FF505050</Color>
    <Color x:Key="StatusBarBackColor">#FF007ACC</Color>
    <Color x:Key="RecordRedColor">#FFF05F5F</Color>
    <Color x:Key="SelectionColor">#FF264F78</Color>

    <SolidColorBrush x:Key="BackgroundBrush"    Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush"       Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SidebarBrush"       Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="EditorBackBrush"    Color="{StaticResource EditorBackColor}" />
    <SolidColorBrush x:Key="ForeBrush"          Color="{StaticResource ForeColor}" />
    <SolidColorBrush x:Key="MutedForeBrush"     Color="{StaticResource MutedForeColor}" />
    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ButtonHoverBrush"   Color="{StaticResource ButtonHoverColor}" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="{StaticResource ButtonPressedColor}" />
    <SolidColorBrush x:Key="StatusBarBackBrush" Color="{StaticResource StatusBarBackColor}" />
    <SolidColorBrush x:Key="RecordRedBrush"     Color="{StaticResource RecordRedColor}" />
    <SolidColorBrush x:Key="SelectionBrush"     Color="{StaticResource SelectionColor}" />
    <SolidColorBrush x:Key="TabActiveBrush"     Color="{StaticResource TabActiveColor}" />
    <SolidColorBrush x:Key="TabInactiveBrush"   Color="{StaticResource TabInactiveColor}" />

</ResourceDictionary>
