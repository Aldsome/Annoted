<Window x:Class="Annoted.Wpf.Views.ReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace" Width="380" Height="180"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource ForeBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Find:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox x:Name="FindBox" Grid.Row="0" Grid.Column="1" Margin="4,4"
                 Background="{DynamicResource BackgroundBrush}"
                 Foreground="{DynamicResource ForeBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" Padding="4"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Replace:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox x:Name="ReplaceBox" Grid.Row="1" Grid.Column="1" Margin="4,4"
                 Background="{DynamicResource BackgroundBrush}"
                 Foreground="{DynamicResource ForeBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" Padding="4"/>
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Replace" Width="80" Margin="0,0,6,0" Click="Replace_Click"/>
            <Button Content="Replace All" Width="90" Margin="0,0,6,0" Click="ReplaceAll_Click"/>
            <Button Content="Close" Width="70" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
