<Window x:Class="Annoted.Wpf.Views.AppearanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Appearance" Width="360" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource ForeBrush}">
    <StackPanel Margin="18">

        <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,6"
                   Foreground="{DynamicResource ForeBrush}"/>
        <StackPanel Margin="0,0,0,16">
            <RadioButton x:Name="SystemRadio" Content="Follow system theme" GroupName="Theme"
                         Margin="0,2" Checked="Theme_Changed"/>
            <RadioButton x:Name="LightRadio" Content="Light" GroupName="Theme"
                         Margin="0,2" Checked="Theme_Changed"/>
            <RadioButton x:Name="DarkRadio" Content="Dark" GroupName="Theme"
                         Margin="0,2" Checked="Theme_Changed"/>
        </StackPanel>

        <TextBlock Text="Editor colors" FontWeight="SemiBold" Margin="0,0,0,6"
                   Foreground="{DynamicResource ForeBrush}"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Background" VerticalAlignment="Center"
                       Foreground="{DynamicResource ForeBrush}"/>
            <Button Grid.Column="1" x:Name="BackSwatch" Width="60" Height="24"
                    Click="ChooseBack_Click"/>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Text" VerticalAlignment="Center"
                       Foreground="{DynamicResource ForeBrush}"/>
            <Button Grid.Column="1" x:Name="ForeSwatch" Width="60" Height="24"
                    Click="ChooseFore_Click"/>
        </Grid>

        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Accent (visualizer, waveform, progress)"
                       VerticalAlignment="Center" TextWrapping="Wrap"
                       Foreground="{DynamicResource ForeBrush}"/>
            <Button Grid.Column="1" x:Name="AccentSwatch" Width="60" Height="24"
                    Click="ChooseAccent_Click"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Reset" Width="64" Margin="0,0,8,0" Click="Reset_Click"/>
            <Button Content="Preview" Width="70" Margin="0,0,8,0" Click="Preview_Click"/>
            <Button Content="Cancel" Width="64" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="OK" Width="64" Click="Ok_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
