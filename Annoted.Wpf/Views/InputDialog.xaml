<Window x:Class="Annoted.Wpf.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Width="360" Height="140"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource ForeBrush}">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptLabel" Margin="0,0,0,8"
                   Foreground="{DynamicResource ForeBrush}"/>
        <TextBox x:Name="InputBox"
                 Background="{DynamicResource BackgroundBrush}"
                 Foreground="{DynamicResource ForeBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 Padding="4" Margin="0,0,0,12"
                 KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     Width="80" Margin="0,0,8,0" Click="Ok_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
