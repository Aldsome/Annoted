<Window x:Class="Annoted.Wpf.Views.DownloadModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speech Model" Width="400" Height="220"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource ForeBrush}">
    <StackPanel Margin="16">
        <TextBlock x:Name="InfoLabel" TextWrapping="Wrap" Margin="0,0,0,10"
                   Foreground="{DynamicResource ForeBrush}"
                   Text="Choose a speech model. Bigger models are more accurate but use much more RAM. Saved beside the app for offline reuse."/>
        <ComboBox x:Name="ModelCombo" Margin="0,0,0,10"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource ForeBrush}"/>
        <ProgressBar x:Name="ProgressBar" Height="18" Margin="0,0,0,4" Maximum="100"/>
        <TextBlock x:Name="ProgressLabel" FontSize="11" Margin="0,0,0,10"
                   Foreground="{DynamicResource MutedForeBrush}" Text=""/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Download" Width="100" Margin="0,0,8,0" Click="Download_Click"/>
            <Button Content="Cancel"   Width="80"  Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
