<UserControl x:Class="Annoted.Wpf.Views.AudioSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Annoted.Wpf.ViewModels"
             Width="290">

    <UserControl.Resources>
        <!-- Flat icon button style (Segoe MDL2 Assets glyphs) -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForeBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Pill-style dictate button (distinct from the square record/transport buttons) -->
        <Style x:Key="DictatePill" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{DynamicResource ForeBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="22" SnapsToDevicePixels="True"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <!-- Active dictation: accent-filled pill -->
                            <DataTrigger Binding="{Binding IsDictating}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderThickness="1,0,0,0" BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource SidebarBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title -->
                <RowDefinition Height="Auto"/>  <!-- Time label -->
                <RowDefinition Height="Auto"/>  <!-- Waveform label -->
                <RowDefinition Height="*"/>     <!-- Memo list -->
                <RowDefinition Height="Auto"/>  <!-- Waveform preview -->
                <RowDefinition Height="Auto"/>  <!-- Button panel -->
                <RowDefinition Height="Auto"/>  <!-- Input device selector -->
            </Grid.RowDefinitions>

            <!-- Title + sort -->
            <Grid Grid.Row="0" Margin="12,8,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Memoirs" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource ForeBrush}"/>
                <ComboBox Grid.Column="1" Width="92" FontSize="11" Margin="0,0,4,0"
                          ItemsSource="{Binding SortModes}" SelectedItem="{Binding SortMode}"
                          ToolTip="Sort Memoirs"/>
                <Button Grid.Column="2" Width="26" Padding="0" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        Command="{Binding ToggleSortDirectionCommand}"
                        Content="{Binding SortAscending, Converter={StaticResource SortArrowConverter}}"
                        ToolTip="Toggle sort direction"/>
            </Grid>

            <!-- Time label + preview volume slider -->
            <Grid Grid.Row="1" Margin="12,0,12,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding TimeLabel}"
                           Foreground="{DynamicResource MutedForeBrush}" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{DynamicResource MutedForeBrush}"/>
                <Slider Grid.Column="2" Minimum="0" Maximum="1" Value="{Binding PreviewVolume, Mode=TwoWay}"
                        VerticalAlignment="Center" SmallChange="0.05" LargeChange="0.2"
                        Foreground="{DynamicResource AccentBrush}" ToolTip="Preview volume"/>
            </Grid>

            <!-- Waveform label -->
            <TextBlock Grid.Row="2"
                       Text="{Binding WaveformLabel}"
                       Foreground="{DynamicResource MutedForeBrush}"
                       FontSize="11" Padding="12,0,12,4"
                       Visibility="{Binding ShowWaveform, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Memo list -->
            <ListBox Grid.Row="3" x:Name="MemoList"
                     ItemsSource="{Binding Memos}"
                     SelectedItem="{Binding SelectedMemo}"
                     SelectionMode="Extended"
                     MouseDoubleClick="MemoList_MouseDoubleClick"
                     KeyDown="MemoList_KeyDown"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource ForeBrush}"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open Note (linked)" Click="Ctx_OpenTab"/>
                        <Separator/>
                        <MenuItem Header="Rename..." Click="Ctx_Rename" InputGestureText="F2"/>
                        <MenuItem Header="Export..." Click="Ctx_Export" InputGestureText="Ctrl+E"/>
                        <MenuItem Header="Move to..." Click="Ctx_Move"/>
                        <MenuItem Header="Delete" Click="Ctx_Delete" InputGestureText="Del"/>
                        <Separator/>
                        <MenuItem Header="Open File Location" Click="Ctx_OpenLocation"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MemoListItem}">
                        <Grid Margin="4,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource ForeBrush}"/>
                                <TextBlock Text="{Binding TabTitle}" FontSize="10"
                                           Foreground="{DynamicResource MutedForeBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Duration}"
                                       FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Foreground="{DynamicResource MutedForeBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="4,2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Waveform preview (hidden when empty/not recording) -->
            <Border Grid.Row="4" Height="150" Margin="8,4"
                    Visibility="{Binding ShowWaveform, Converter={StaticResource BoolToVisibility}}">
                <Grid x:Name="WaveformHost"
                      MouseLeftButtonDown="Waveform_MouseDown"
                      MouseMove="Waveform_MouseMove"
                      Background="Transparent">
                    <!-- Static waveform bitmap (only when no live capture is running) -->
                    <Image Source="{Binding WaveformImage}" Stretch="Fill"
                           Visibility="{Binding IsVisualizerActive, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <!-- Red playhead during preview playback -->
                    <Canvas x:Name="PlayheadCanvas"
                            Visibility="{Binding IsVisualizerActive, Converter={StaticResource InverseBoolToVisibility}}">
                        <Line x:Name="Playhead" Y1="0" Stroke="#E03030" StrokeThickness="1.5" Visibility="Collapsed"/>
                    </Canvas>
                    <!-- Shared audio visualizer: ball (dictate) / crescent (record), drawn in code-behind -->
                    <Canvas x:Name="DictationCanvas"
                            Visibility="{Binding IsVisualizerActive, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Border>

            <!-- Button panel: 5 per row, wraps -->
            <WrapPanel Grid.Row="5" Orientation="Horizontal" Margin="6" HorizontalAlignment="Left">

                <!-- Record -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding RecordCommand}"
                        IsEnabled="{Binding CanRecord}"
                        ToolTip="Record">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource RecordRedBrush}"/>
                </Button>

                <!-- Stop -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding StopAudioCommand}"
                        IsEnabled="{Binding CanStop}"
                        ToolTip="Stop"
                        Content="&#xE71A;"/>

                <!-- Pause -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding PauseAudioCommand}"
                        IsEnabled="{Binding CanPause}"
                        ToolTip="Pause"
                        Content="&#xE769;"/>

                <!-- Resume -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding ResumeAudioCommand}"
                        IsEnabled="{Binding CanResume}"
                        ToolTip="Resume"
                        Content="&#xE768;"/>

                <!-- Play/Pause -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding PlaySelectedCommand}"
                        IsEnabled="{Binding CanPlay}"
                        ToolTip="{Binding IsPlaying, Converter={StaticResource PlayPauseTooltipConverter}}">
                    <TextBlock Text="{Binding IsPlaying, Converter={StaticResource PlayPauseGlyphConverter}}"
                               FontFamily="Segoe MDL2 Assets"/>
                </Button>

                <!-- Dictate (pill-style) -->
                <Button Style="{StaticResource DictatePill}"
                        Command="{Binding ToggleDictationCommand}"
                        IsEnabled="{Binding CanDictate}"
                        ToolTip="{Binding IsDictating, Converter={StaticResource DictateTooltipConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding IsDictating, Converter={StaticResource DictateGlyphConverter}}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Dictate" FontSize="12" Margin="6,0,2,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Export -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding ExportCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Export WAV"
                        Content="&#xE78C;"/>

                <!-- Rename -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding RenameCommand}"
                        IsEnabled="{Binding CanRename}"
                        ToolTip="Rename"
                        Content="&#xE70F;"/>

                <!-- Delete -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding DeleteCommand}"
                        IsEnabled="{Binding CanDelete}"
                        ToolTip="Delete"
                        Content="&#xE74D;"/>

                <!-- Open Location -->
                <Button Style="{StaticResource SidebarButton}"
                        Command="{Binding OpenLocationCommand}"
                        IsEnabled="{Binding CanOpenLocation}"
                        ToolTip="Open File Location"
                        Content="&#xE8DA;"/>

            </WrapPanel>

            <!-- Input device selector -->
            <StackPanel Grid.Row="6" Margin="12,4,12,10">
                <TextBlock Text="Microphone" FontSize="10"
                           Foreground="{DynamicResource MutedForeBrush}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding InputDevices}"
                          SelectedItem="{Binding SelectedInputDevice}"
                          DisplayMemberPath="Name"
                          ToolTip="Recording input device"
                          FontSize="11"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
